{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "STM32 ST-Link: Build + Flash + Debug",
            "type": "cortex-debug",
            "request": "launch",
            "cwd": "${workspaceFolder}",
            "preLaunchTask": "Build Debug",
            "servertype": "stlink",
            "serverpath": "D:/ST/STM32CubeCLT_1.21.0/STLink-gdb-server/bin/ST-LINK_gdbserver.exe",
            "armToolchainPath": "D:/ST/STM32CubeCLT_1.21.0/GNU-tools-for-STM32/bin",
            "gdbPath": "D:/ST/STM32CubeCLT_1.21.0/GNU-tools-for-STM32/bin/arm-none-eabi-gdb.exe",
            "device": "STM32F103C8",
            "interface": "swd",
            "runToEntryPoint": "main",
            "executable": "${workspaceFolder}/build/Debug/STM32_ESC_Telemetry_Test.elf",
            "showDevDebugOutput": "none",
            "preRestartCommands": [
                "monitor reset"
            ]
        }
    ]
}
